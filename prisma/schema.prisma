generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NETLIFY_DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  arcNumber     String?  // Foreigner Registration Number (ARC)
  name          String
  preferredLang String   @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applications  Application[]
}

model Application {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  planId           String   // 'light', 'standard', 'premium'
  deliveryMethod   String   // 'esim', 'delivery', 'airport'
  deliveryAddress  String?
  paymentMethod    String?
  status           String   @default("pending") // pending, approved, completed, rejected
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
